# Authentication key — used to authenticate the Go agent WebSocket connection
# and as base material for AES-256-GCM encryption of Oracle credentials.
# Generate with: openssl rand -hex 32
AGENT_API_KEY=sk_replace_with_secure_random_key

# Oracle database connection details
ORACLE_HOST=192.168.1.10
ORACLE_PORT=1521
ORACLE_SERVICE=ORCL
ORACLE_USER=usuario
ORACLE_PASSWORD=senha
